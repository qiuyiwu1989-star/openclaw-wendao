# 问道 环境变量

# 必填：LLM 网关密钥（服务端使用，绝不暴露给前端；对话 + TTS 共用）
LLM_API_KEY=

# LLM 网关根地址（小米 MiMo 网关）
#   对话走 ${LLM_BASE}/anthropic（Anthropic 兼容）
#   语音走 ${LLM_BASE}/v1/chat/completions（TTS 模型）
LLM_BASE=https://token-plan-cn.xiaomimimo.com

# 对话模型（mimo-v2.5-pro 更会思考；mimo-v2.5 更快）
WENDAO_MODEL=mimo-v2.5-pro

# 单次回复最大 token（含模型思考，留足余量；可见回答由提示词约束为短）
WENDAO_MAX_TOKENS=1024

# 语音合成模型 + 音色（预置音色：冰糖/茉莉 女，苏打/白桦 男，Mia/Chloe/Milo/Dean 英文）
WENDAO_TTS_MODEL=mimo-v2.5-tts
WENDAO_TTS_VOICE=冰糖

# 可选：以子路径部署时设置，如 /wendao
# BASE_PATH=/wendao
